{
  "expo": {
    "name": "Traefik Manager",
    "slug": "traefik-manager-mobile",
    "version": "0.3.0",
    "orientation": "portrait",
    "scheme": "traefikmanager",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "ios": {
      "icon": "./assets/icon.png",
      "bundleIdentifier": "dev.chr0nzz.traefikmanager"
    },
    "android": {
      "package": "dev.chr0nzz.traefikmanager",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d1117"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0d1117",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "dark": {
            "backgroundColor": "#0d1117",
            "image": "./assets/splash-icon.png"
          }
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "89ea617e-460f-45e6-90b1-ff436cb32b23"
      }
    },
    "owner": "chronzz"
  }
}
